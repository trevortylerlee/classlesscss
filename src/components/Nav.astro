---
import { themes } from "../data/themes";
---

<nav id="nav">
  <div class="nav-left">
    <a href="/" id="nav-home">Home</a>
    <a href="/about" id="nav-about">About</a>
  </div>
  <div class="nav-right">
    <select id="theme-select" aria-label="Select a CSS theme">
      <option value="">Select a theme</option>
      {themes.map((theme) => (
        <option value={theme.slug}>
          {theme.title}
        </option>
      ))}
    </select>
    <button id="random-theme" type="button">Random</button>
  </div>
</nav>

<style>
  #nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 0;
  }

  .nav-left {
    display: flex;
    gap: 0.75rem;
    align-items: center;
  }

  .nav-right {
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }
</style>

<script is:inline define:vars={{ themes }}>
  (function () {
    var params = new URLSearchParams(window.location.search);
    var slug = params.get("theme");

    var homeLink = document.getElementById("nav-home");
    var aboutLink = document.getElementById("nav-about");
    var select = document.getElementById("theme-select");
    var randomBtn = document.getElementById("random-theme");

    function updateNavLinks(themeSlug) {
      var suffix = themeSlug ? "?theme=" + themeSlug : "";
      if (homeLink) homeLink.href = "/" + suffix;
      if (aboutLink) aboutLink.href = "/about" + suffix;
    }

    function applyTheme(newSlug) {
      var url = new URL(window.location.href);
      if (newSlug) {
        url.searchParams.set("theme", newSlug);
      } else {
        url.searchParams.delete("theme");
      }
      history.pushState(null, "", url.toString());

      var theme = newSlug
        ? themes.find(function (t) { return t.slug === newSlug; })
        : null;

      var oldLink = document.getElementById("theme-stylesheet");
      if (oldLink) oldLink.remove();

      if (theme) {
        var link = document.createElement("link");
        link.id = "theme-stylesheet";
        link.rel = "stylesheet";
        link.href = theme.cdn;
        document.head.appendChild(link);
      }

      updateNavLinks(newSlug);

      if (select) select.value = newSlug || "";
    }

    // Set initial state
    updateNavLinks(slug);
    if (select && slug) select.value = slug;

    if (select) {
      select.addEventListener("change", function () {
        applyTheme(select.value);
      });
    }

    if (randomBtn && select) {
      randomBtn.addEventListener("click", function () {
        var options = Array.from(select.options).filter(function (o) {
          return o.value;
        });
        var random = options[Math.floor(Math.random() * options.length)];
        if (random) {
          applyTheme(random.value);
        }
      });
    }
  })();
</script>
