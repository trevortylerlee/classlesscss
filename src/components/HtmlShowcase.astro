<!-- Image -->
<h2 id="image">
  <a href="https://developer.mozilla.org/docs/Web/HTML/Element/img">Image</a>
</h2>
<figure>
  <img
    src="/tunisia.jpg"
    alt="George Lucas and Anthony Daniels (C-3PO) talking on the set of Star Wars (1977)."
  />
  <figcaption>
    George Lucas and Anthony Daniels (C-3PO) talking on the set of
    <cite>Star Wars</cite> (1977).
  </figcaption>
</figure>

<!-- Audio and Video -->
<h2 id="media">
  <a href="https://developer.mozilla.org/docs/Web/HTML/Element/audio"
    >Audio and Video</a
  >
</h2>
<h3>Audio</h3>
<audio controls src="/purple-lightsaber.mp3"></audio>
<h3>Video</h3>
<video controls src="/sw.mp4" width="640" height="480"></video>

<!-- Forms -->
<h2 id="form">
  <a href="https://developer.mozilla.org/docs/Web/HTML/Element/form">Forms</a>
</h2>
<form>
  <fieldset>
    <legend>Text Inputs</legend>
    <p>
      <label for="text-input">Text</label>
      <input id="text-input" placeholder="Text input" type="text" />
    </p>
    <p>
      <label for="email-input">Email</label>
      <input id="email-input" placeholder="email@example.com" type="email" />
    </p>
    <p>
      <label for="textarea-input">Textarea</label>
      <textarea
        id="textarea-input"
        placeholder="Enter longer text here"
        rows="4"></textarea>
    </p>
  </fieldset>
  <fieldset>
    <legend>Selection</legend>
    <p>
      <label for="select-input">Select</label>
      <select id="select-input">
        <option>Option 1</option>
        <option>Option 2</option>
        <option>Option 3</option>
      </select>
    </p>
  </fieldset>
  <fieldset>
    <legend>Radio Buttons</legend>
    <input type="radio" id="radio-1" name="radio" value="1" />
    <label for="radio-1">Option 1</label><br />
    <input type="radio" id="radio-2" name="radio" value="2" />
    <label for="radio-2">Option 2</label><br />
    <input type="radio" id="radio-3" name="radio" value="3" />
    <label for="radio-3">Option 3</label>
  </fieldset>
  <fieldset>
    <legend>Checkboxes</legend>
    <input type="checkbox" id="cb-1" name="cb-1" value="1" />
    <label for="cb-1">Option 1</label><br />
    <input type="checkbox" id="cb-2" name="cb-2" value="2" />
    <label for="cb-2">Option 2</label><br />
    <input type="checkbox" id="cb-3" name="cb-3" value="3" />
    <label for="cb-3">Option 3</label>
  </fieldset>
  <p><button type="button">Button</button></p>
</form>

<!-- Details -->
<h2 id="details">
  <a href="https://developer.mozilla.org/docs/Web/HTML/Element/details"
    >Details</a
  >
</h2>
<details>
  <summary>Click to expand</summary>
  <p>
    The <code>&lt;details&gt;</code> element creates a disclosure widget that the
    user can open and close. No JavaScript required.
  </p>
</details>

<!-- Dialog -->
<h2 id="dialog">
  <a href="https://developer.mozilla.org/docs/Web/HTML/Element/dialog">Dialog</a
  >
</h2>
<dialog id="favDialog">
  <form method="dialog">
    <p>This is a <code>&lt;dialog&gt;</code> modal window.</p>
    <p><button>Close</button></p>
  </form>
</dialog>
<button id="openDialog">Open Dialog</button>
<script is:inline>
  document.getElementById("openDialog")?.addEventListener("click", function () {
    var dialog = document.getElementById("favDialog");
    if (dialog && typeof dialog.showModal === "function") {
      dialog.showModal();
    }
  });
</script>

<!-- Code -->
<h2 id="code">
  <a href="https://developer.mozilla.org/docs/Web/HTML/Element/code">Code</a>
</h2>
<p>
  Inline code: <code>console.log("hello world")</code>
</p>
<h3>Preformatted Text</h3>
<pre><code>&lt;!DOCTYPE html&gt;
&lt;html lang="en"&gt;
  &lt;head&gt;
    &lt;title&gt;Hello&lt;/title&gt;
  &lt;/head&gt;
  &lt;body&gt;
    &lt;p&gt;Hello, world!&lt;/p&gt;
  &lt;/body&gt;
&lt;/html&gt;</code></pre>
<h3>Keyboard Input and Sample Output</h3>
<p>Press <kbd>Ctrl</kbd> + <kbd>C</kbd> to copy text (Windows).</p>
<p>Press <kbd>Cmd</kbd> + <kbd>C</kbd> to copy text (Mac).</p>
<p>Sample output: <samp>File not found. Press F1 to continue</samp></p>

<!-- Progress and Meter -->
<h2 id="progress">
  <a href="https://developer.mozilla.org/docs/Web/HTML/Element/progress"
    >Progress and Meter</a
  >
</h2>
<p>
  <label for="progress-bar">Download progress:</label>
  <progress id="progress-bar" value="32" max="100">32%</progress>
</p>
<p>
  Tickets sold: <meter min="0" max="100" value="75"></meter> 75%
</p>

<!-- Horizontal Rule -->
<h2 id="hr">
  <a href="https://developer.mozilla.org/docs/Web/HTML/Element/hr"
    >Horizontal Rule</a
  >
</h2>
<p>A horizontal rule separates content:</p>
<hr />
<p>Content continues after the rule.</p>
