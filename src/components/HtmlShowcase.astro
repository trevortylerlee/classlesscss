---
import { themes } from "../data/themes";
---

<p id="current-theme-info" style="display:none;"></p>
<script is:inline define:vars={{ themes }}>
  (function () {
    function updateThemeInfo() {
      var slug = new URLSearchParams(window.location.search).get("theme");
      var el = document.getElementById("current-theme-info");
      if (!el) return;
      if (!slug) {
        el.style.display = "none";
        el.innerHTML = "";
        return;
      }
      var theme = themes.find(function (t) {
        return t.slug === slug;
      });
      if (!theme) {
        el.style.display = "none";
        el.innerHTML = "";
        return;
      }
      el.innerHTML =
        'You are viewing <a href="' + theme.link + '">' + theme.title + "</a>";
      el.style.display = "";
    }

    updateThemeInfo();

    var origPushState = history.pushState;
    history.pushState = function () {
      origPushState.apply(this, arguments);
      updateThemeInfo();
    };
  })();
</script>

